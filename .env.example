# Django
DJANGO_SECRET_KEY=replace-me-in-prod
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# Database
POSTGRES_DB=interview_judge
POSTGRES_USER=interview_judge
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis - Patch #4: NO DEFAULTS in settings.py; missing values must crash
# These two MUST be different instances; sharing them couples our real-time SLO
# to Judge0's queue depth.
CHANNELS_REDIS_URL=redis://redis-channels:6379/0
JUDGE0_REDIS_URL=redis://redis-judge0:6379/0

# Judge0
JUDGE0_BASE_URL=http://judge0-server:2358
JUDGE0_CALLBACK_BASE_URL=http://web:8000
JUDGE0_CALLBACK_HMAC_SECRET=replace-me-in-prod

# Cookie signing
INTERVIEW_SESSION_COOKIE_NAME=interview_session
INTERVIEW_SESSION_COOKIE_MAX_AGE_SECONDS=18000

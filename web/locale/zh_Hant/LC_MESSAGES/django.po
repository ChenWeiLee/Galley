msgid "Notice"
msgstr "通知"

msgid "Notice of Admission"
msgstr "入場通知"

msgid "Time has <em>elapsed.</em>"
msgstr "時間已 <em>結束</em>"

msgid "This interview has <em>concluded.</em>"
msgstr "面試已 <em>結束</em>"

msgid "Cannot <em>enter</em> the interview."
msgstr "無法 <em>進入</em> 面試。"

msgid ""
"Your browser session has expired, or this browser does not carry a valid "
"credential for the interview."
msgstr "你的瀏覽器 session 已過期，或此瀏覽器沒有有效的面試憑證。"

msgid "We could not locate the requested interview session in our records."
msgstr "找不到對應的面試場次。"

msgid ""
"The interviewer has marked this session complete. Your answer was saved."
msgstr "面試官已標記此場次為已結束，你的答案已儲存。"

msgid ""
"The allotted time has run out — your final answer was captured and saved "
"automatically. Please return to your interviewer."
msgstr "面試時間結束 — 系統已自動擷取並儲存你的最終答案，請回到面試官身邊。"

msgid ""
"The link you used is no longer valid. Tokens are single-use by design; once "
"consumed they cannot be re-used."
msgstr "你使用的連結已失效。連結為一次性設計，使用過後即無法再次進入。"

msgid ""
"If you closed the tab in error, please ask your interviewer to mint a fresh "
"re-entry link from their dashboard. Re-entry is rate-limited to three per "
"session."
msgstr ""
"若你不小心關閉了分頁，請請面試官於儀表板核發新的重新進入連結。每場最多三次重"
"新進入。"

